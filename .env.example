# ============================================
# Living Runbooks Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Slack Integration
# ============================================
# Get these from https://api.slack.com/apps
SLACK_SIGNING_SECRET=xoxp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ============================================
# PagerDuty Integration
# ============================================
# Get from https://app.pagerduty.com/settings/integrations/api
PAGERDUTY_API_KEY=u+...
PAGERDUTY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Datadog Integration
# ============================================
# Get from https://app.datadoghq.com/organization-settings/api-keys
DATADOG_API_KEY=your_api_key_here
DATADOG_APP_KEY=your_app_key_here
DATADOG_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Prometheus AlertManager Integration
# ============================================
# URL to your AlertManager instance
ALERTMANAGER_URL=http://localhost:9093
ALERTMANAGER_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Sentry Integration
# ============================================
# Get from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_API_TOKEN=your_token_here
SENTRY_ORG_SLUG=your_organization_slug

# ============================================
# LLM Integration (Optional but Recommended)
# ============================================
# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your_secret_key_for_sessions

# ============================================
# FastAPI Configuration
# ============================================
# Comma-separated list of allowed origins (use * for development)
ALLOWED_ORIGINS=*

# ============================================
# Database (Optional - for future PostgreSQL support)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/runbooks

# ============================================
# Redis (Optional - for caching and WebSocket)
# ============================================
# REDIS_URL=redis://localhost:6379/0

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Git Configuration (for version control)
# ============================================
# Git user for automated commits
GIT_AUTHOR_NAME=runbook-bot
GIT_AUTHOR_EMAIL=runbook-bot@runbooks.local

# ============================================
# Security
# ============================================
# Enable/disable path traversal protection (always true in production)
SECURE_PATH_VALIDATION=true

# ============================================
# Feature Flags
# ============================================
# Enable/disable specific features
ENABLE_AI_SUGGESTIONS=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_GIT_VERSIONING=true
ENABLE_AUTO_REMEDIATION=false
